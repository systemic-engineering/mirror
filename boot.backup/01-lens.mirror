grammar @lens {
  type = iso | lens | prism | traversal | fold | setter
  type composition = then | compose | identity

  type preview = satisfiable | unsatisfiable | partial
  type delta = converged | diverged

  action project(spec: grammar)
  action preview(projection: preview)
  action measure(projection: preview, actual: grammar)
}

in @conversation
in @prism
