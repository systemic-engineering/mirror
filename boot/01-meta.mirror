in @prism

focus type(id)
project ref(type)

split |(ref, ref)
zoom |>(ref, prism)
zoom <|(prism, ref)
zoom /(ref, focus)
refract ..(ref)

type loss(f64)
type precision(f64)

type beam(result) {
  result: result,
  path: [prism],
  loss: loss
  precision: precision
}

form @meta {
  focus @
  project |>
  split |
  zoom /
  refract ..
}

out type
out ref
out |
out |>
out /
out ..
out loss
out precision
out beam
out @meta
