in @prism
in @actor

type grammar
type action(grammar)

type invocation(grammar, action) {
  grammar: grammar,
  action: action(grammar),
  input: imperfect,
  output: imperfect,
}

prism @action(grammar, action) {
  focus  grammar -> action
  project action(input) -> output
  split  output -> imperfect
  zoom   imperfect -> transport
  refract transport -> crystal
}

out grammar
out action
out invocation
out @action
