in @prism
in @actor

type grammar
type block(grammar)

prism action {
  focus  type -> grammar
  project grammar -> block
  split  block(grammar) -> imperfect
  zoom   imperfect -> transport
  refract transport -> crystal
}

action action(receiver: type, in: grammar, body: block(grammar)) {
  focus  receiver
  project in
  split  body(in)
  zoom   body -> imperfect
  refract imperfect
}

out grammar
out block
out action
