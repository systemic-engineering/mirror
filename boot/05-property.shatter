grammar @property {
  in @meta

  type verdict = imperfect(declaration, property_error, property_loss)

  type property_error {
    observation: declaration,
    property: text,
    context: [declaration],
  }

  type property_loss {
    deviation: f64,
    frequency: imperfect,
  }

  type effect_pattern = effect(a, b)
}

out verdict
out property_error
out property_loss
out effect_pattern
out @property
