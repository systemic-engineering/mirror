---

@test {
  merge_duplicate_lenses: lens dedup {
    assert field(name) = field(name)
    assert property(value) = property(value)
  }

  merge_traversals: traversal deduplicate {
    keep collection(item)
  }

  merge_prism_option: prism merge {
    unify optional(content)
  }

  merge_fold_aggregate: fold accumulate {
    combine aggregate(sum)
  }
}
