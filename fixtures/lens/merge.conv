lens field(name)
lens field(name)
lens field(name)

lens property(value)
lens property(value)
lens property(value)
lens property(value)

traversal collection(item)
traversal collection(item)
traversal collection(item)

prism optional(content)
prism optional(content)

fold aggregate(sum)
fold aggregate(sum)

iso identity(stable)
iso identity(stable)

lens field(name)
lens property(value)
traversal collection(item)

