traversal flat_pile = parse | resolve | compile | check | generate | emit | load | run | halt | parse | resolve
fold gather(flat_pile)
fold gather(flat_pile)
fold gather(flat_pile)
traversal signal = critical | important
traversal noise = tmp1 | tmp2 | tmp3 | tmp4 | tmp5 | tmp6 | tmp7 | tmp8
prism filter(signal, noise)
lens type(id)
lens type(id)
lens type(id)
lens ref(id)
lens ref(id)
lens grammar(ref)
lens grammar(ref)
traversal monolith = auth | cache | log | trace | deploy | monitor | scale | test | lint | validate
lens split(monolith)
fold deep_start
lens descend(deep_start)
prism narrow(descend)
lens focus(narrow)
fold observe(focus)
traversal wide = a | b | c | d | e | f
traversal also_wide = g | h | i | j | k | l
lens merge(wide, also_wide)
iso attempt_settle
traversal contradiction_a = up | down
traversal contradiction_b = down | up
prism conflict(contradiction_a, contradiction_b)
lens resolve_or_escalate(conflict)
fold rest
