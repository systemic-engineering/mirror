in @sha512 as @oid
in @git(namespace: "conversation")

grammar @conversation {
  type = grammar | type | action
}

grammar @prism {
  type = in | out | template | field | pipe
}

grammar @lens {
  type = iso | lens | prism | traversal | fold | setter
  type composition = then | compose | identity
}

grammar @test {
  type = assertion | property
  type assertion = has | eq
  type property = requires | invariant | ensures
}

---

test "conversation defines grammars" {
  @conversation has grammar
  @conversation has type
  @conversation has action
}

test "prism defines structure" {
  @prism has in
  @prism has out
  @prism has template
  @prism has field
  @prism has pipe
}

test "lens defines optics" {
  @lens has iso
  @lens has lens
  @lens has prism
  @lens has traversal
  @lens has fold
  @lens has setter
  @lens.composition has then
  @lens.composition has compose
  @lens.composition has identity
}

test "test defines verification" {
  @test has assertion
  @test has property
  @test.assertion has has
  @test.assertion has eq
  @test.property has requires
  @test.property has invariant
  @test.property has ensures
}
